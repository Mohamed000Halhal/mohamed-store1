rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mohamedemara@stroe.com';
    }

    // --- Public Read Access ---

    // Products: Read for everyone, Write for Admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (UI/Colors): Read for everyone, Write for Admin
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Order Related ---

    // Orders: Anyone can create (customer), only Admin can read/update/delete
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Deleted Orders: Admin only
    match /deletedOrders/{orderId} {
      allow read, write: if isAdmin();
    }

    // --- User & Cart Related ---

    // Users: Each user can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Carts: Each user can read/write their own cart
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Admin/System Utilities ---
    
    // Admin tokens for notifications
    match /adminTokens/{tokenId} {
      allow read, write: if isAdmin();
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }
    
    // Admin stats
    match /adminStats/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Admin presence
    match /adminPresence/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Admin session logs
    match /adminSessionLog/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Contact messages
    match /contacts/{contactId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
  }
}
